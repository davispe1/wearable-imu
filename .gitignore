# --- Session data ---
# Keep only the two bundled examples (P04 real session, SYN01 synthetic session),
# the Rajagopal OpenSense model, and the tiny schema example. Any new session you
# create locally (e.g. `python -m tools.make_synthetic_session` re-run, or your own
# recordings) stays untracked unless you remove it from this list on purpose.
data/*
!data/schema_example.csv
!data/Rajagopal_OpenSense/
!data/P04_S01_2minWalk/
!data/SYN01_S01_straightWalk/

